#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${ROOT}"

stop_tunnel() {
  if pgrep -f "[m]inikube tunnel" >/dev/null 2>&1; then
    echo "==> Stop minikube tunnel"
    sudo pkill -f "[m]inikube tunnel" || true
  else
    echo "==> minikube tunnel (not running)"
  fi
}

if [[ "${1:-}" == "tunnel" ]]; then
  stop_tunnel
  exit 0
fi

if [[ "${1:-}" == "all" ]]; then
  echo "==> Remove all resources including PVCs (data will be lost)"
  kubectl delete -k . --ignore-not-found
  stop_tunnel
  echo "==> Done"
  exit 0
fi

echo "==> Remove workloads (PVCs kept — Jaeger, OpenObserve, Prometheus data preserved)"
kubectl delete deployment,statefulset,ingress,service -n observability --ignore-not-found
kubectl delete configmap -n observability otel-collector-config prometheus-config --ignore-not-found

stop_tunnel

cat <<EOF
==> Done (minikube cluster is still running; run 'minikube stop' to stop the VM)

Data volumes kept. Redeploy: ./bin/start-local
Delete data too:       ./bin/stop-local all

EOF
